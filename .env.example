# Skill-Connect Environment Variables
# Copy this file to .env (for local dev) or set these in Vercel Dashboard → Settings → Environment Variables

# ── Required ──────────────────────────────────────────────────────────────────

# Vercel Postgres (Neon) connection string
# Get this from: Vercel Dashboard → Storage → Create Database → Postgres
# For local dev, you can use a free Neon account: https://neon.tech
POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require

# JWT signing secret — use a long, random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# ── Optional: AI Features ──────────────────────────────────────────────────────

# Google Gemini API key — enables real AI suggestions & analysis
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Optional: OAuth Integrations ──────────────────────────────────────────────

# GitHub OAuth App (for linking GitHub profiles)
# Create one at: https://github.com/settings/developers
# Callback URL: https://your-vercel-url.vercel.app/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LinkedIn Developer App (for linking LinkedIn profiles)
# Create one at: https://developer.linkedin.com/
# Callback URL: https://your-vercel-url.vercel.app/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Your deployed app URL (used for OAuth redirect URIs)
APP_URL=https://your-project.vercel.app
